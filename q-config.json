{
  "mode": "normal",
  "sensitivity": "normal",
  "model_fast": "claude-haiku-4-5-20251001",
  "model_normal": "claude-sonnet-4-6",
  "watched_extensions": [".py", ".ts", ".js", ".go", ".java", ".cs", ".rb", ".php", ".swift", ".kt"],
  "exclude_patterns": [
    "**/node_modules/**",
    "**/.git/**",
    "**/dist/**",
    "**/out/**",
    "**/build/**",
    "**/__pycache__/**",
    "**/*.min.js",
    "**/*.min.css",
    "**/vendor/**"
  ],
  "rate_limit_per_minute": 10,
  "p3_silent": true,
  "max_diff_lines": 300,

  "kb_path": "knowledge_base",
  "domains_path": "knowledge_base/domains",
  "verdicts_path": "knowledge_base/verdicts/index.md",

  "team_exceptions_path": "knowledge_base/team/exceptions/approved.md",
  "personal_kb_path": "knowledge_base/personal/q-learned.md",

  "team_mode": true,
  "ci_gate_severities": ["P0", "P1"],
  "advisory_only": false,

  "anthropic_api_key_env": "ANTHROPIC_API_KEY"
}
